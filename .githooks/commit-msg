#!/usr/bin/env node

import fs from "node:fs";

const messagePath = process.argv[2];
const rawMessage = fs.readFileSync(messagePath, "utf8");
const lines = rawMessage
  .split(/\r?\n/)
  .map((line) => line.trimEnd());
const subject = lines.find((line) => line.trim() && !line.trim().startsWith("#")) || "";

const allowedTypes = ["功能", "修复", "文档", "样式", "重构", "性能", "测试", "维护", "回滚"];
const autoGeneratedPatterns = [
  /^Merge\b/,
  /^Revert\b/,
  /^fixup! /,
  /^squash! /
];

if (autoGeneratedPatterns.some((pattern) => pattern.test(subject))) {
  process.exit(0);
}

const subjectPattern = /^(功能|修复|文档|样式|重构|性能|测试|维护|回滚)\(([^()\s][^()]*)\):\s(\p{Extended_Pictographic}(?:\uFE0F|\u{1F3FB}|\u{1F3FC}|\u{1F3FD}|\u{1F3FE}|\u{1F3FF})?)\s(.+)$/u;
const match = subject.match(subjectPattern);

if (!match) {
  fail([
    "提交信息格式不符合 TeleBridge 规范。",
    "",
    "格式：<中文类型>(<作用域>): <emoji> <中文简短描述>",
    "示例：功能(userbot): ✨ 增加保活消息通知",
    "",
    `允许的中文类型：${allowedTypes.join("、")}`
  ]);
}

const description = match[4].trim();

if (!containsChinese(description)) {
  fail(["提交简短描述必须使用中文。"]);
}

if (/[。.!！?？]$/.test(description)) {
  fail(["提交简短描述结尾不加句号或标点。"]);
}

process.exit(0);

function containsChinese(value) {
  return /[\u3400-\u9FFF]/.test(value);
}

function fail(messages) {
  console.error(messages.join("\n"));
  process.exit(1);
}
